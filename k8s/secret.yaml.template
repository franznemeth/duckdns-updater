apiVersion: v1
kind: Secret
metadata:
  name: duckdns-secret
  namespace: default   # adjust to your target namespace
type: Opaque
stringData:
  # Paste your DuckDNS token here, then apply with:
  #   kubectl apply -f k8s/secret.yaml
  #
  # DO NOT commit a real token — add this file to .gitignore if you fill it in locally.
  token: "<YOUR_DUCKDNS_TOKEN>"

